# Copy to backend.hcl (gitignored) and run: terraform init -backend-config=backend.hcl
# One-time bucket/table setup: bash infra/ci/bootstrap-state.sh

bucket         = "REPLACE_WITH_YOUR_TF_STATE_BUCKET"
key            = "netknife/dev/terraform.tfstate"
region         = "us-west-2"
dynamodb_table = "REPLACE_WITH_YOUR_TF_STATE_LOCK_TABLE"
encrypt        = true

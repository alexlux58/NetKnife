# Production build environment for NetKnife frontend.
# Copy to .env.production (gitignored) and fill in values from Terraform outputs,
# or run ./update-env.sh to generate .env.production automatically.
#
# cp .env.production.example .env.production

VITE_API_URL=https://your-api-id.execute-api.us-west-2.amazonaws.com
VITE_COGNITO_DOMAIN=https://your-project-xxxx.auth.us-west-2.amazoncognito.com
VITE_COGNITO_CLIENT_ID=your-cognito-app-client-id
VITE_COGNITO_ISSUER=https://cognito-idp.us-west-2.amazonaws.com/us-west-2_XXXXXXXXX
VITE_OIDC_REDIRECT_URI=https://your-site.example.com/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=https://your-site.example.com/login
VITE_REGION=us-west-2
VITE_DEV_BYPASS_AUTH=false
